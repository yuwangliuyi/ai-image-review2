# 环境变量配置模板
# 复制此文件为 .env 并修改：cp .env.example .env

# SQLite 数据库文件路径（本地开发用 file:./dev.db 即可）
DATABASE_URL="file:./dev.db"

# NextAuth 密钥（生产环境务必换成随机字符串：openssl rand -hex 32）
NEXTAUTH_SECRET="change-me-to-a-random-string-in-production"

# 服务地址（部署时改成实际 IP 或域名）
NEXTAUTH_URL="http://localhost:8001"

# 审核通过图片的结构化储存根目录（可选，默认项目根下的 approved-images/）
# APPROVED_STORAGE_ROOT="./approved-images"
